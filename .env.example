# OpenAI
OPENAI_API_KEY=sk-xxx

# Server
PORT=18790
NODE_ENV=production

# Database (SQLite path)
DATABASE_PATH=./data/bot.db

# Conversation settings
CONTEXT_LAST_N_MESSAGES=20
SYNC_IDLE_MINUTES=10

# CRM (Monday.com example - adjust for your CRM)
CRM_TYPE=monday
CRM_API_KEY=xxx
CRM_BOARD_ID=xxx

# Webhook security
WEBHOOK_SECRET=change-me-to-random-string

# Cloudflare Tunnel (optional)
TUNNEL_NAME=hai-tech-bot
